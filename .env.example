# =============================================================================
# BASE LOCAL (copiar este archivo a `.env`)
# =============================================================================
DJANGO_DEBUG=True
ENVIRONMENT=dev
DJANGO_SECRET_KEY=""
DJANGO_ALLOWED_HOSTS="localhost,127.0.0.1"

# =============================================================================
# BASE DE DATOS
# =============================================================================
DATABASE_HOST="mysql"
DATABASE_PORT="3306"
DATABASE_USER="root"
DATABASE_PASSWORD="root1-password2"
DATABASE_NAME="sisoc-local"
WAIT_FOR_DB=true
DB_CONN_MAX_AGE=0
DB_CONN_HEALTH_CHECKS=false

# =============================================================================
# DJANGO/GUNICORN
# =============================================================================
RUN_MAKEMIGRATIONS_ON_START=true
GUNICORN_WORKERS=4
GUNICORN_THREADS=1

# =============================================================================
# SEGURIDAD / CSP
# =============================================================================
ENABLE_CSP=true
CSP_REPORT_ONLY=true
CSP_ALLOW_UNSAFE_INLINE_SCRIPTS=false
CSP_ALLOW_UNSAFE_EVAL=false

# =============================================================================
# DOCKER
# =============================================================================
DOCKER_MYSQL_PORT_FORWARD=3307
DOCKER_MYSQL_PORT=3306
DOCKER_DJANGO_PORT_FORWARD=8001
DOCKER_DJANGO_PORT=8000
DOCKER_DEBUGGER_PORT_FORWARD=3000
DOCKER_DEBUGGER_PORT=3000
RUN_UID=0
RUN_GID=0

# =============================================================================
# THREADING / ASYNC
# =============================================================================
DISABLE_ASYNC_THREADS=false

# =============================================================================
# GESTIONAR
# =============================================================================
GESTIONAR_API_KEY="V2-XkNF1-jpWZ1-sR5LX"
GESTIONAR_API_CREAR_RELEVAMIENTO="localhost:8001"
GESTIONAR_API_BORRAR_RELEVAMIENTO="localhost:8001"
GESTIONAR_API_CREAR_PRESTACIONES="localhost:8001"
GESTIONAR_API_CREAR_COMEDOR="localhost:8001"
GESTIONAR_API_BORRAR_COMEDOR="localhost:8001"
GESTIONAR_API_CREAR_OBSERVACION="localhost:8001"
GESTIONAR_API_CREAR_REFERENTE="localhost:8001"
GESTIONAR_WORKERS=2
GESTIONAR_COMEDORES_WORKERS=2
GESTIONAR_RELEVAMIENTOS_WORKERS=2
DOMINIO="http://localhost:8001/"

# =============================================================================
# RENAPER
# =============================================================================
RENAPER_API_USERNAME="ssph-sisoc@secretarianaf.gob.ar"
RENAPER_API_PASSWORD="Sisoc2025*"
RENAPER_API_URL="https://wsv2.secretarianaf.gob.ar/api"
RENAPER_VALIDACION_MAX_RETRIES=1
RENAPER_VALIDACION_BACKOFF_SECONDS=0.0

# =============================================================================
# SENTRY
# =============================================================================
SENTRY_ENABLED=true
SENTRY_DSN=""
SENTRY_ENVIRONMENT=dev
SENTRY_RELEASE=0.0
SENTRY_SEND_DEFAULT_PII=false
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_PROFILES_SAMPLE_RATE=0.0

# =============================================================================
# EXTRAS
# =============================================================================
LOG_DIR="logs"
CHANGELOG_GITHUB_URL="https://raw.githubusercontent.com/dsocial118/BACKOFFICE/main/CHANGELOG.md"
