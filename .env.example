# =============================================================================
# BASE LOCAL (copiar este archivo a `.env`)
# =============================================================================
DJANGO_DEBUG=True
ENVIRONMENT=dev
DJANGO_SECRET_KEY=""
DJANGO_ALLOWED_HOSTS="localhost,127.0.0.1"

# =============================================================================
# BASE DE DATOS
# =============================================================================
DATABASE_HOST="mysql" # ⚠️
DATABASE_PORT="3306"
DATABASE_USER="root" # ⚠️
DATABASE_PASSWORD="root1-password2" # ⚠️
DATABASE_NAME="sisoc-local" # ⚠️
WAIT_FOR_DB=true
DB_CONN_MAX_AGE=0
DB_CONN_HEALTH_CHECKS=false

# =============================================================================
# DJANGO/GUNICORN
# =============================================================================
RUN_MAKEMIGRATIONS_ON_START=true
GUNICORN_WORKERS=4
GUNICORN_THREADS=1

# =============================================================================
# SEGURIDAD / CSP
# =============================================================================
ENABLE_CSP=true
CSP_REPORT_ONLY=true
CSP_ALLOW_UNSAFE_INLINE_SCRIPTS=false
CSP_ALLOW_UNSAFE_EVAL=false

# =============================================================================
# DOCKER
# =============================================================================
DOCKER_MYSQL_PORT_FORWARD=3307
DOCKER_MYSQL_PORT=3306
DOCKER_DJANGO_PORT_FORWARD=8001
DOCKER_DJANGO_PORT=8000
DOCKER_DEBUGGER_PORT_FORWARD=3000
DOCKER_DEBUGGER_PORT=3000
RUN_UID=0
RUN_GID=0

# =============================================================================
# THREADING / ASYNC
# =============================================================================
DISABLE_ASYNC_THREADS=false

# =============================================================================
# TESTING
# =============================================================================
USE_SQLITE_FOR_TESTS=1
PYTEST_RUNNING=0

# =============================================================================
# GESTIONAR
# =============================================================================
GESTIONAR_API_KEY="" # ⚠️
GESTIONAR_API_CREAR_RELEVAMIENTO="localhost:8001" # ⚠️
GESTIONAR_API_BORRAR_RELEVAMIENTO="localhost:8001" # ⚠️
GESTIONAR_API_CREAR_PRESTACIONES="localhost:8001" # ⚠️
GESTIONAR_API_CREAR_COMEDOR="localhost:8001" # ⚠️
GESTIONAR_API_BORRAR_COMEDOR="localhost:8001" # ⚠️
GESTIONAR_API_CREAR_OBSERVACION="localhost:8001" # ⚠️
GESTIONAR_API_CREAR_REFERENTE="localhost:8001" # ⚠️
GESTIONAR_WORKERS=2
GESTIONAR_COMEDORES_WORKERS=2
GESTIONAR_RELEVAMIENTOS_WORKERS=2
DOMINIO="http://localhost:8001/"

# =============================================================================
# RENAPER
# =============================================================================
RENAPER_API_USERNAME="" # ⚠️
RENAPER_API_PASSWORD="" # ⚠️
RENAPER_VALIDACION_MAX_RETRIES=1
RENAPER_VALIDACION_BACKOFF_SECONDS=0.0

# =============================================================================
# GOOGLE MAPS (opcional)
# =============================================================================
GOOGLE_MAPS_API_KEY=""

# =============================================================================
# SENTRY
# =============================================================================
SENTRY_ENABLED=true
SENTRY_DSN=""
SENTRY_RELEASE=0.0
SENTRY_SEND_DEFAULT_PII=false

# =============================================================================
# EXTRAS
# =============================================================================
LOG_DIR="logs"
LOG_FALLBACK_DIR="/tmp/sisoc-logs"

# =============================================================================
# EMAIL / PASSWORD RESET
# =============================================================================
# Si EMAIL_BACKEND queda vacio, SISOC usa backend de consola (no envía, solo loggea).
EMAIL_BACKEND=""
EMAIL_HOST="localhost"
EMAIL_PORT=587
EMAIL_HOST_USER=""
EMAIL_HOST_PASSWORD=""
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_TIMEOUT=10
DEFAULT_FROM_EMAIL="no-reply@sisoc.local"
PASSWORD_RESET_TIMEOUT=3600
INITIAL_PASSWORD_MAX_AGE_HOURS=336
