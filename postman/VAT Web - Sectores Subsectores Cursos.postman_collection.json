        {
          "name": "Consultar estado de voucher por documento",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "{{authHeader}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}{{apiPrefix}}/vat/web/ciudadanos/voucher-estado/?documento={{documento}}",
              "host": [
                "{{baseUrl}}{{apiPrefix}}"
              ],
              "path": [
                "vat",
                "web",
                "ciudadanos",
                "voucher-estado",
                ""
